#!/usr/bin/env bash
# Pre-push hook: mirrors GitHub CI checks before any push is accepted.
# Install via: make install-hooks
# To skip (emergency only): git push --no-verify

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

BOLD='\033[1m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RESET='\033[0m'

echo ""
echo -e "${BOLD}--- Pre-push checks (mirroring GitHub CI) ---${RESET}"
echo ""

if ! command -v uv &>/dev/null; then
    echo -e "${RED}ERROR: 'uv' not found on PATH.${RESET}"
    echo "  Run: curl -Ls https://astral.sh/uv/install.sh | sh"
    exit 1
fi

echo -e "${BOLD}[1/2] Running lint (pre-commit: black, flake8, isort)...${RESET}"
if ! uv run pre-commit run --all-files; then
    echo ""
    echo -e "${RED}${BOLD}PUSH ABORTED: Lint checks failed.${RESET}"
    echo -e "  Fix the issues above, stage your changes, and push again."
    echo -e "  Tip: run ${YELLOW}make lint${RESET} to debug interactively."
    echo ""
    exit 1
fi
echo -e "${GREEN}  Lint passed.${RESET}"
echo ""

# echo -e "${BOLD}[2/2] Running tests (pytest)...${RESET}"
# set +e
# uv run pytest
# pytest_exit=$?
# set -e

# Exit code 5 = no tests collected (allowed for now)
# Exit code 0 = tests passed
# Other exit codes = test failure
# if [ $pytest_exit -eq 0 ] || [ $pytest_exit -eq 5 ]; then
#     if [ $pytest_exit -eq 0 ]; then
#         echo -e "${GREEN}  Tests passed.${RESET}"
#     else
#         echo -e "${GREEN}  No tests yet (0 tests collected).${RESET}"
#     fi
#     echo ""
# else
#     echo ""
#     echo -e "${RED}${BOLD}PUSH ABORTED: Tests failed.${RESET}"
#     echo -e "  Fix the failing tests, then push again."
#     echo -e "  Tip: run ${YELLOW}make test${RESET} to debug interactively."
#     echo ""
#     exit 1
# fi

echo -e "${GREEN}${BOLD}All checks passed. Pushing...${RESET}"
echo ""
exit 0
